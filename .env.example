# Copy this file to .env before using docker-compose.prod.yml.

DASHSCOPE_CODING_API_KEY=replace-me
DEEPSEEK_API_KEY=replace-me
XIAOMI_MIMO_API_KEY=replace-me
HOST=0.0.0.0
PORT=3000
HOST_PORT=3000
WEB_ACCESS_BROWSER_GUI_PORT=3901
WEB_ACCESS_BROWSER_PROFILE_DIR=/config/chrome-profile-sidecar
WEB_ACCESS_BROWSER_PUBLIC_BASE_URL=http://ugk-pi:3000
WEB_ACCESS_BROWSER_UPLOAD_APP_DIR=/app/.data/browser-upload
WEB_ACCESS_BROWSER_UPLOAD_BROWSER_DIR=/config/upload
UGK_BROWSER_MEM_LIMIT=2g
UGK_BROWSER_MEM_RESERVATION=512m
CONN_WORKER_MAX_CONCURRENCY=3
SEARXNG_BASE_URL=http://ugk-pi-searxng:8080
SEARXNG_HOST_PORT=48080
# Generate a random production secret, for example: openssl rand -hex 32
SEARXNG_SECRET=replace-me-with-random-secret
UGK_SEARXNG_MEM_LIMIT=512m
UGK_SEARXNG_MEM_RESERVATION=128m
PUBLIC_BASE_URL=https://your-public-host.example.com
# Feishu app credentials can be set in Web -> 飞书设置 after first boot.
# These env values are bootstrap fallbacks for fresh deployments.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_API_BASE=https://open.feishu.cn/open-apis
FEISHU_ENABLED=false
FEISHU_SUBSCRIPTION_MODE=ws
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_AGENT_BASE_URL=http://127.0.0.1:3000
# These are fallback values. Web -> 飞书设置 persists runtime values in .data/agent/feishu/settings.json.
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_ACTIVITY_CHAT_IDS=
FEISHU_ACTIVITY_OPEN_IDS=
UGK_APP_ENV_FILE=.env
UGK_APP_LOG_DIR=./logs/app
UGK_AGENT_DATA_DIR=./.data/agent
UGK_AGENTS_DATA_DIR=./.data/agents
UGK_MODEL_SETTINGS_PATH=/app/.data/agent/model-settings.json
UGK_NGINX_LOG_DIR=./logs/nginx
UGK_BROWSER_CONFIG_DIR=./.data/chrome-sidecar
UGK_BROWSER_UPLOAD_DIR=./.data/chrome-sidecar/upload
UGK_SEARXNG_CONFIG_DIR=./deploy/searxng
UGK_SEARXNG_CACHE_DIR=./.data/searxng
# Production should point this at shared storage, not the clean Git worktree.
# Tencent example: /home/ubuntu/ugk-claw-shared/runtime/skills-user
# Aliyun example: /root/ugk-claw-shared/runtime/skills-user
UGK_RUNTIME_SKILLS_USER_DIR=./runtime/skills-user

# Optional Docker build mirror host for Debian apt sources.
# Example for Aliyun ECS: mirrors.aliyun.com
APT_MIRROR_HOST=
