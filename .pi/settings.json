{
  // "shellPath": "C:\\Windows\\System32\\cmd.exe",  // Windows 下临时启用
  "defaultProvider": "deepseek",
  "defaultModel": "deepseek-v4-flash",
  "defaultThinkingLevel": "medium",
  "sessionDir": ".pi/sessions",
  "enableSkillCommands": true,
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "maxDelayMs": 60000
  },
  "prompts": ["prompts"],
  "skills": ["skills"],
  "extensions": ["extensions"]
}
